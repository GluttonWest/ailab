import random

house = [[random.choice(["clean", "dirty"]) for _ in range(3)] for _ in range(3)]

i, j = 1, 1
steps = 0

def display():
    print("\nHouse:")
    for row in house:
        print(row)
    print()

def sense():
    return house[i][j]

def move_up():
    global i
    if i > 0:
        i -= 1
    print("Move up")

def move_down():
    global i
    if i < 2:
        i += 1
    print("Move down")

def move_left():
    global j
    if j > 0:
        j -= 1
    print("Move left")

def move_right():
    global j
    if j < 2:
        j += 1
    print("Move right")

def clean():
    print(f"Cleaning square ({i}, {j})")
    house[i][j] = "clean"

# Simple systematic traversal (row-wise)
def next_move():
    global i, j
    if j < 2:
        return "right"
    elif i < 2:
        return "down"
    else:
        return "stop"
display()
print("Agent starts at:", (i, j))

while True:
    percept = sense()
    steps += 1

    if percept == "dirty":
        clean()
        continue

    action = next_move()

    if action == "right":
        move_right()
    elif action == "down":
        move_down()
        j = 0  # reset column when moving to next row
    elif action == "stop":
        print("Finished")
        break

display()
print("Total steps:", steps)
