import random
from collections import deque

SIZE = 3
house = [[random.choice(["clean", "dirty"]) for _ in range(SIZE)] for _ in range(SIZE)]
OBSTACLE = (0, 1)
pos = (1, 1)
battery, steps = 10, 0

def show():
    print("\nHouse:")
    for r in range(SIZE):
        print([("X" if (r, c) == OBSTACLE else house[r][c]) for c in range(SIZE)])

def bfs(start, goal):
    q = deque([(start, [])])
    visited = {start}
    while q:
        (r, c), path = q.popleft()
        if (r, c) == goal:
            return path
        for dr, dc in [(-1,0),(1,0),(0,-1),(0,1)]:
            nr, nc = r+dr, c+dc
            if 0 <= nr < SIZE and 0 <= nc < SIZE and (nr, nc) not in visited and (nr, nc) != OBSTACLE:
                visited.add((nr, nc))
                q.append(((nr, nc), path + [(nr, nc)]))
    return []

show()
print("Start:", pos)

while any("dirty" in row for row in house):
    r, c = pos

    if house[r][c] == "dirty":
        print(f"Cleaning {r},{c}")
        house[r][c] = "clean"
        continue

    if battery <= 2:
        print("Recharging...")
        for step in bfs(pos, (0, 0)):
            pos = step; battery -= 1; steps += 1
        battery = 10
        continue

    # find any dirty cell
    target = next(((i, j) for i in range(SIZE) for j in range(SIZE) if house[i][j]=="dirty"), None)
    path = bfs(pos, target) if target else []

    if path:
        pos = path[0]; battery -= 1; steps += 1
    else:
        break

# return to start
for step in bfs(pos, (1, 1)):
    pos = step; battery -= 1; steps += 1

show()
print("Final:", pos, "| Steps:", steps, "| Battery:", battery)
